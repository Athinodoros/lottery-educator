{
  "name": "lottery-educator",
  "version": "0.1.0",
  "description": "Educational lottery simulator to teach users about the unlikeliness of winning",
  "private": true,
  "workspaces": [
    "backend/*",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspaces",
    "dev": "npm run dev --workspaces",
    "dev:backend": "npm run dev --workspace=backend/api-gateway & npm run dev --workspace=backend/game-engine & npm run dev --workspace=backend/statistics & npm run dev --workspace=backend/email-service & npm run dev --workspace=backend/metrics-service",
    "dev:gateway": "npm run dev --workspace=backend/api-gateway",
    "dev:games": "npm run dev --workspace=backend/game-engine",
    "dev:stats": "npm run dev --workspace=backend/statistics",
    "dev:email": "npm run dev --workspace=backend/email-service",
    "dev:metrics": "npm run dev --workspace=backend/metrics-service",
    "build": "npm run build --workspaces",
    "test": "npm test --workspaces",
    "lint": "npm run lint --workspaces",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "lottery",
    "education",
    "gambling",
    "probability",
    "typescript"
  ],
  "author": "CodingAltar",
  "license": "MIT"
}
